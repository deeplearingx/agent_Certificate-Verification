FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PROJECT_ROOT=/app

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./requirements.txt

# MinerU is optional because some environments cannot install it directly from PyPI.
# With INSTALL_MINERU=0 the image still supports FastAPI, Streamlit integration,
# and dry-run / service smoke testing. Real PDF->MD parsing requires MinerU.
ARG INSTALL_MINERU=0
RUN python - <<'PY'
from pathlib import Path

src = Path("requirements.txt")
dst = Path("requirements.docker.txt")
lines = src.read_text(encoding="utf-8").splitlines()
filtered = [line for line in lines if "mineru" not in line.lower()]
dst.write_text("\n".join(filtered) + "\n", encoding="utf-8")
PY

RUN pip install -r requirements.docker.txt
RUN if [ "$INSTALL_MINERU" = "1" ]; then pip install mineru; fi

COPY . /app

RUN mkdir -p /app/local_pdf /app/local_md /app/local_json /app/final_reports /app/reports /app/output

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -fsS http://127.0.0.1:8000/api/v1/health || exit 1

CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]

